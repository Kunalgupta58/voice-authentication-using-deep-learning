# Example environment variables for Hugging Face Spaces + Neon deployment

# Neon/Postgres connection
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# JWT configuration
SECRET_KEY=replace-this-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256

# Backend startup behavior
PRELOAD_MODEL=0
WEB_CONCURRENCY=1

# Static frontend + CORS
CORS_ORIGINS=*

# Temporary runtime paths (optional on HF Spaces)
MODEL_CACHE_DIR=/tmp/spkrec-ecapa-voxceleb
TEMP_AUDIO_DIR=/tmp/voicekey_temp_audio
